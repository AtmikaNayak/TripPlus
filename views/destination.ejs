<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= data.name %>
    </title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <nav>
        <img src="/logo.png">
        <h3><a href="/">Home</a></h3>
        <h3><a href="/destinations">Destinations</a></h3>
        <h3><a href="/packages">Packages</a></h3>
        <h3><a href="/contact">Contact</a></h3>
    </nav>
    <div class="destscontent">
        <img src="/<%= data.image %>" />
        <div>
            <h1>
                <%= data.name %>
            </h1>
            <p>
                <%= data.itinerary %>
            </p>
            <p>
                <%= data.price %>
            </p>
            <p>
                <%= data.duration %>
            </p>
        </div>
    </div>
    <footer class="footer">
        <div class="footer-container">
            <div class="footer-column">
                <h4>Company</h4>
                <ul>
                    <li>About Us</li>
                    <li>Careers</li>
                    <li>Press</li>
                    <li>Travel Blog</li>
                </ul>
            </div>
            <div class="footer-column">
                <h4>Support</h4>
                <ul>
                    <li>Help Center & FAQ</li>
                    <li>Contact Us</li>
                    <li>Cancellation Policy</li>
                    <li>Accessibility</li>
                </ul>
            </div>
            <div class="footer-column">
                <h4>Legal</h4>
                <ul>
                    <li>Terms of Service</li>
                    <li>Privacy Policy</li>
                    <li>Cookie Policy</li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="copyright">
                <p>&copy; 2026 TripPlus. All rights reserved.</p>
            </div>
            <div class="social-links">
                <p>Instagram</p>
                <p>TikTok</p>
                <p>Facebook</p>
            </div>
        </div>
    </footer>
</body>

</html>